# SQLite for local dev. For production, swap the datasource provider to
# "postgresql" and point this at your Postgres instance (see README "Releasing v1").
DATABASE_URL="file:./dev.db"

# Admin views (/admin/login). This dev default is REJECTED in production builds —
# set a long random ADMIN_KEY in your deployment env.
ADMIN_KEY="local-admin"

# Production-only (set in the deployment env, not here — this file is committed):
# IP_HASH_SALT=<long random string; without it production stores no IP digests>
# NEXT_PUBLIC_SITE_URL=https://your-domain.example
# ANTHROPIC_API_KEY=<only needed for scripts/generate.ts>
