// Judgment Call — Milestone 1 schema.
// SQLite for local dev; designed to swap to Postgres by changing the
// datasource provider + DATABASE_URL only. Enum-like fields are stored as
// strings (validated in src/lib/types.ts) because SQLite has no native enums —
// this also keeps the Postgres migration a pure config change.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Finding {
  id             String       @id @default(cuid())
  title          String
  domain         String // earnings | econ | sports | ops
  contextSnippet String // markdown, shown in the swipe header
  sourceLabel    String
  truthSummary   String // ground-truth claim every faithful variant must respect
  status         String       @default("active") // active | submitted | retired
  sourceUrl      String? // provenance for ingested/public-source findings
  retrievedAt    DateTime? // when the source data was fetched
  staleAfter     DateTime? // matchmaking stops serving past this date
  deck           Deck?        @relation(fields: [deckId], references: [id])
  deckId         String? // null = public pool; set = private BYO deck
  variants       Variant[]
  comparisons    Comparison[]
}

model Variant {
  id              String  @id @default(cuid())
  finding         Finding @relation(fields: [findingId], references: [id])
  findingId       String
  text            String
  leadType        String // number_first | implication_first | question_first
  lengthBand      String // short | medium | long
  caveatPlacement String // upfront | trailing | omitted
  quantification  String // precise | rounded | qualitative
  soWhat          String // explicit | implied
  fidelity        String  @default("faithful") // faithful | overclaimed (hidden experiment flag)
  status          String  @default("approved") // pending | approved | rejected (M2 review gate; only approved is served)
  source          String  @default("seed") // seed | generated
  version         Int     @default(1) // variant text is immutable once voted on; edits create a new version
  selfCheck       String? // JSON claims ledger from the generation self-check (M2)
  elo             Float   @default(1200)
  wins            Int     @default(0)
  losses          Int     @default(0)

  comparisonsAsA Comparison[] @relation("variantA")
  comparisonsAsB Comparison[] @relation("variantB")
  comparisonsWon Comparison[] @relation("winner")

  @@index([findingId])
}

model Comparison {
  id           String   @id @default(cuid())
  finding      Finding  @relation(fields: [findingId], references: [id])
  findingId    String
  variantA     Variant  @relation("variantA", fields: [variantAId], references: [id])
  variantAId   String
  variantB     Variant  @relation("variantB", fields: [variantBId], references: [id])
  variantBId   String
  winner       Variant? @relation("winner", fields: [winnerId], references: [id])
  winnerId     String? // null = "can't decide"
  // POSITION INVARIANT: variantA is ALWAYS rendered left (desktop) / top (mobile).
  // The server randomizes which variant lands in slot A, so position bias is
  // measurable as variantA's overall win rate vs 50%.
  session      Session  @relation(fields: [sessionId], references: [id])
  sessionId    String
  segment      String // denormalized from session for easy analytics cuts
  contrastAttrs String // comma-joined sorted attribute keys the pair differed on, e.g. "leadType"
  latencyMs    Int
  lowAttention Boolean  @default(false) // latencyMs < 800; included in Elo, excludable in analytics
  isRepeat     Boolean  @default(false) // session saw this pair before (exhaustion fallback); non-independent, exclude from analytics
  isGold       Boolean  @default(false) // pair had a strong prior consensus when this vote was cast (judge scoring)
  postDrill    Boolean  @default(false) // session had completed >=1 overclaim drill before this vote — lets the fidelity analysis cut naive vs trained judges
  deckId       String? // BYO-data deck scope; null = the public study
  ipHash       String? // salted SHA-256 of client IP — sybil forensics only, never reversible
  userAgent    String?
  createdAt    DateTime @default(now())

  @@index([sessionId])
  @@index([findingId])
}

model Session {
  id          String       @id // client-generated UUID (localStorage)
  segment     String // executive | analyst | data_leader | other
  referrer    String? // document.referrer at landing, for share-loop attribution
  utmSource   String? // ?utm_source= at landing
  voteCount   Int          @default(0)
  // Judge quality (ROADMAP §2): agreement with strong-consensus "gold" pairs.
  // Re-weights analysis only — never gates voting, never trains generation.
  goldCount     Int    @default(0)
  goldAgreement Int    @default(0)
  judgeScore    Float? // goldAgreement/goldCount once goldCount >= 3
  // Progression (cosmetic only — NEVER read by analytics; judgeScore alone
  // re-weights analysis). XP rewards volume and coverage, not agreement.
  xp           Int    @default(0)
  // Skill: Rasch-style judge ability updated per gold vote against the pair's
  // consensus-margin difficulty. Display + robustness cuts only.
  judgeAbility Float?
  // Drill track (chess-puzzles analog): Elo vs item ratings, separate world
  // from the study; drillCount also stamps Comparison.postDrill.
  drillRating Float @default(1200)
  drillCount  Int   @default(0)
  // Public taste permalink (opt-in): set once when the owner publishes their
  // profile; /p/[publicSlug] renders the poster read-only. Craft only — the
  // personal-results blinding rules apply unchanged.
  publicSlug String? @unique
  createdAt   DateTime       @default(now())
  comparisons Comparison[]
  decks       Deck[]
  xpEvents    XpEvent[]
  drillAttempts DrillAttempt[]
}

// Auditable XP ledger — every point traceable, like everything else in the study.
model XpEvent {
  id        String   @id @default(cuid())
  session   Session  @relation(fields: [sessionId], references: [id])
  sessionId String
  kind      String // vote | first_contrast | frontier | run_complete | daily | drill
  amount    Int
  detail    String?
  createdAt DateTime @default(now())

  @@index([sessionId])
}

// "Spot the overclaim" training items. Purpose-built content, fully separate
// from study findings: drill attempts never touch analytics, and drill items
// are never served in the voting pool.
model DrillItem {
  id              String         @id @default(cuid())
  title           String
  contextSnippet  String
  sourceLabel     String
  faithfulText    String
  overclaimedText String
  explanation     String // the claims-ledger reveal shown after an attempt
  device          String // the overclaim device used, e.g. "trend extrapolation"
  rating          Float          @default(1200)
  attempts        Int            @default(0)
  status          String         @default("active") // active | retired
  createdAt       DateTime       @default(now())
  drillAttempts   DrillAttempt[]
}

model DrillAttempt {
  id          String    @id @default(cuid())
  session     Session   @relation(fields: [sessionId], references: [id])
  sessionId   String
  item        DrillItem @relation(fields: [drillItemId], references: [id])
  drillItemId String
  correct     Boolean
  latencyMs   Int
  createdAt   DateTime  @default(now())

  @@index([sessionId])
  @@index([drillItemId])
}

// BYO-data deck (ROADMAP §3): a private pool of findings owned by the session
// that submitted them. Deck votes never mix into the public study.
model Deck {
  id             String    @id @default(cuid())
  slug           String    @unique
  name           String
  owner          Session   @relation(fields: [ownerSessionId], references: [id])
  ownerSessionId String
  visibility     String    @default("private") // private | public (public = promoted to the pool)
  createdAt      DateTime  @default(now())
  findings       Finding[]
}

// Admin paper trail (ROADMAP §4): every consequential admin action.
model AuditEvent {
  id        String   @id @default(cuid())
  actor     String // "admin" (single-operator for now)
  action    String // e.g. variant.approve, variant.reject, finding.retire
  subject   String // id of the thing acted on
  detail    String? // e.g. rejection reason — feeds generation negative exemplars
  createdAt DateTime @default(now())
}

// Recursive-learning snapshots (ROADMAP §1): one row per analysis run.
model AnalysisSnapshot {
  id           String   @id @default(cuid())
  method       String // e.g. "logistic-diff-v1"
  coefficients String // JSON: per attribute-value effect + intervals, per segment
  coverage     String // JSON: value-pair n per segment, starvation ranking
  createdAt    DateTime @default(now())
}

// Tunable matchmaking weights (ROADMAP-2 §1). Single row, admin-edited, audited.
// Policy changes ship like prompt changes: replay-evaluated first.
model ServingPolicy {
  id        String   @id @default("default")
  config    String // JSON: { fidelityBoost, earlyFidelityCap, capUntilVotes }
  updatedAt DateTime @updatedAt
}
